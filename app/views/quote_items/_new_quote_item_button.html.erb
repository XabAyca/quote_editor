<%= turbo_frame_tag :new_quote_item do %>
  <div class="border-2 border-dashed border-gray-300 rounded-lg py-5 flex justify-center mb-10">
    <%= link_to new_quote_quote_item_path(@quote), data: { turbo_stream: true }, class: "inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 rounded shadow-sm hover:bg-gray-50 text-slate-900 font-medium" do %>
      <%= icon :plus, class: "w-4 h-4", "stroke-width": "2" %>
      <%= t(".add") %>
    <% end %>
  </div>
<% end %>
