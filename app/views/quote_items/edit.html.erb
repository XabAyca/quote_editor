<%= turbo_frame_tag @quote_item do %>
  <div class="grid grid-cols-12 gap-4 items-center px-6 py-4 bg-violet-50 rounded">
    <%= form_with model: [@quote, @quote_item], class: "contents" do |f| %>
      <%= f.text_field :name,
            autofocus: true,
            class: "col-span-3 px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-violet-500" %>
      <%= f.number_field :quantity,
            step: "0.5",
            class: "col-span-1 px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-violet-500" %>
      <%= f.number_field :unit_price,
            step: "0.01",
            class: "col-span-1 px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-violet-500" %>
      <%= f.select :vat_rate,
            [["5,5 %", 5.5], ["10 %", 10], ["20 %", 20]],
            {},
            class: "col-span-1 px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-violet-500" %>

      <div class="col-span-2 font-semibold text-slate-900"><%= number_to_currency(@quote_item.total_excl_tax_cents / 100.0) %></div>
      <div class="col-span-2 font-semibold text-slate-900"><%= number_to_currency(@quote_item.total_incl_tax_cents / 100.0) %></div>

      <div class="col-span-2 flex gap-2 justify-end">
        <%= f.submit "✓",
              class: "px-4 py-2 bg-yellow-500 text-white rounded hover:bg-yellow-600 cursor-pointer" %>
        <%= link_to "Annuler", quote_quote_items_path(@quote),
              class: "px-2 py-2 text-gray-600 hover:text-gray-900" %>
      </div>
    <% end %>
  </div>

  <% if @quote_item.errors.any? %>
    <p class="mt-2 text-sm text-red-600"><%= @quote_item.errors.full_messages.to_sentence %></p>
  <% end %>
<% end %>
