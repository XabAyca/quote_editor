<%= turbo_frame_tag quote_item do %>
  <% quote = quote_item.quote %>
  <div class="grid grid-cols-12 gap-4 items-center px-6 py-4">
    <div class="col-span-3 font-bold text-slate-900"><%= quote_item.name %></div>
    <div class="col-span-1 text-sm text-gray-500"><%= number_with_precision(quote_item.quantity, strip_insignificant_zeros: true) %></div>
    <div class="col-span-1 text-sm text-gray-500"><%= number_to_currency(quote_item.unit_price) %></div>
    <div class="col-span-1 text-sm text-gray-500"><%= number_with_precision(quote_item.vat_rate, strip_insignificant_zeros: true) %>%</div>
    <div class="col-span-2 font-semibold text-slate-900"><%= number_to_currency(quote_item.total_excl_tax_cents / 100.0) %></div>
    <div class="col-span-2 font-semibold text-slate-900"><%= number_to_currency(quote_item.total_incl_tax_cents / 100.0) %></div>
    <div class="col-span-2 flex gap-2 justify-end">
      <% unless quote.validated? %>
        <%= link_to edit_quote_quote_item_path(quote, quote_item), class: "p-2 bg-slate-900 text-white rounded hover:bg-slate-800", aria: { label: t(".edit") } do %>
          <%= icon :pencil %>
        <% end %>
        <%= button_to quote_quote_item_path(quote, quote_item), method: :delete, form: { data: { turbo_confirm: t(".confirm_destroy") } }, class: "cursor-pointer p-2 bg-orange-500 text-white rounded hover:bg-orange-600", aria: { label: t(".destroy") } do %>
          <%= icon :trash %>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
